---
// Renders a horizontal pipeline architecture diagram as inline SVG.
interface Props {
  label: string;
  nodes: string[];
  accent?: 'mint' | 'violet';
}
const { label, nodes, accent = 'mint' } = Astro.props;
const colorVar = accent === 'mint' ? '--c-accent' : '--c-accent2';
const color = `rgb(var(${colorVar}))`;

const BOX_W = 148;
const BOX_H = 52;
const GAP = 42;
const PAD = 12;
const width = nodes.length * BOX_W + (nodes.length - 1) * GAP + PAD * 2;
const height = BOX_H + PAD * 2 + 26;
---

<figure class="panel overflow-x-auto p-4">
  <figcaption class="mb-3 font-mono text-xs uppercase tracking-widest text-dim">
    {label}
  </figcaption>
  <svg
    viewBox={`0 0 ${width} ${height}`}
    class="min-w-[640px] w-full"
    role="img"
    aria-label={`Architecture: ${nodes.join(' → ')}`}
  >
    {
      nodes.map((n, i) => {
        const x = PAD + i * (BOX_W + GAP);
        const y = PAD + 13;
        return (
          <g>
            <rect
              x={x}
              y={y}
              width={BOX_W}
              height={BOX_H}
              style="fill: rgb(var(--c-surface))"
              style={`stroke: ${i === nodes.length - 1 ? color : 'rgb(var(--c-dim) / 0.35)'}`}
              stroke-width="1"
            />
            <text
              x={x + BOX_W / 2}
              y={y + BOX_H / 2 + 4}
              text-anchor="middle"
              font-family="'IBM Plex Mono', monospace"
              font-size="11"
              style={`fill: ${i === nodes.length - 1 ? color : 'rgb(var(--c-dim))'}`}
            >
              {n.length > 20 ? n.slice(0, 19) + '…' : n}
            </text>
            <text
              x={x + 6}
              y={y - 5}
              font-family="'IBM Plex Mono', monospace"
              font-size="9"
              style="fill: rgb(var(--c-faint))"
            >
              {String(i + 1).padStart(2, '0')}
            </text>
            {i < nodes.length - 1 && (
              <g>
                <line
                  x1={x + BOX_W}
                  y1={y + BOX_H / 2}
                  x2={x + BOX_W + GAP - 8}
                  y2={y + BOX_H / 2}
                  style={`stroke: ${color}`}
                  stroke-width="1"
                  stroke-dasharray="4 3"
                  opacity="0.6"
                />
                <path
                  d={`M ${x + BOX_W + GAP - 8} ${y + BOX_H / 2 - 4} l 8 4 l -8 4 z`}
                  style={`fill: ${color}`}
                  opacity="0.8"
                />
              </g>
            )}
          </g>
        );
      })
    }
  </svg>
</figure>
