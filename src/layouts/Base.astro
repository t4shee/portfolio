---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/global.css';
import { identity } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = `${identity.name} — ${identity.title}`,
  description = `${identity.name} · ${identity.title}. ${identity.tagline} National hackathon winner, IndiaSkills medallist, GATE CSE qualified. AI/ML, cybersecurity, SOC operations, LLM security.`,
  path = '/',
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://tasheebisht.pages.dev';
const canonical = `${site}${path}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: identity.name,
  url: site,
  jobTitle: identity.title,
  description: identity.tagline,
  alumniOf: {
    '@type': 'CollegeOrUniversity',
    name: 'National Forensic Sciences University',
  },
  knowsAbout: [
    'Artificial Intelligence',
    'Machine Learning',
    'Cybersecurity',
    'LLM Security',
    'SOC Operations',
    'Software Engineering',
    'DevSecOps',
  ],
  sameAs: [identity.github, identity.linkedin],
};
---

<!doctype html>
<html lang="en" class="grid-bg">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={identity.name} />
    <meta
      name="keywords"
      content="Tashee Bisht, AI security engineer, cybersecurity researcher, machine learning, LLM security, SOC, NFSU, portfolio"
    />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#0A0E14" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={identity.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site}/og-image.svg`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}/og-image.svg`} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />

    <script>
      // Scroll-reveal via IntersectionObserver — transform/opacity only (GPU-composited)
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
