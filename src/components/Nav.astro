---
import { identity } from '../data/profile';
const links = [
  ['about', '/#about'],
  ['experience', '/#experience'],
  ['projects', '/#projects'],
  ['skills', '/#skills'],
  ['achievements', '/#achievements'],
  ['contact', '/#contact'],
];
---

<header class="fixed top-0 z-50 w-full border-b border-line bg-void/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-content items-center justify-between px-4 py-3 md:px-6" aria-label="Main">
    <a href="/" class="font-mono text-sm font-medium text-ink" data-cursor="home">
      <span class="text-accent">~/</span>{identity.handle}
      <span class="cursor-blink text-accent">_</span>
    </a>
    <div class="hidden gap-6 lg:flex">
      {links.map(([label, href]) => (
        <a href={href} class="font-mono text-xs text-dim transition-colors hover:text-accent">
          ./{label}
        </a>
      ))}
    </div>
    <div class="flex items-center gap-3">
    <button
      id="theme-toggle"
      type="button"
      aria-label="Toggle light/dark theme"
      data-cursor="theme"
      class="border border-line px-2.5 py-1.5 font-mono text-xs text-dim transition-colors hover:border-accent/50 hover:text-accent"
    >◐</button>
    <a
      href={identity.linkedin}
      target="_blank"
      rel="noopener noreferrer"
      data-cursor="connect"
      class="panel px-3 py-1.5 font-mono text-xs text-accent transition-colors hover:border-accent/60"
    >
      connect →
    </a>
    </div>
  </nav>
</header>
