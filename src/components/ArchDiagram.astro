---
// Renders a horizontal pipeline architecture diagram as inline SVG.
interface Props {
  label: string;
  nodes: string[];
  accent?: 'cyan' | 'violet';
}
const { label, nodes, accent = 'cyan' } = Astro.props;
const color = accent === 'cyan' ? '#22D3EE' : '#8B5CF6';

const BOX_W = 148;
const BOX_H = 52;
const GAP = 42;
const PAD = 12;
const width = nodes.length * BOX_W + (nodes.length - 1) * GAP + PAD * 2;
const height = BOX_H + PAD * 2 + 26;
---

<figure class="hud overflow-x-auto p-4">
  <figcaption class="mb-3 font-mono text-xs uppercase tracking-widest text-faint">
    {label}
  </figcaption>
  <svg
    viewBox={`0 0 ${width} ${height}`}
    class="min-w-[640px] w-full"
    role="img"
    aria-label={`Architecture: ${nodes.join(' → ')}`}
  >
    {
      nodes.map((n, i) => {
        const x = PAD + i * (BOX_W + GAP);
        const y = PAD + 13;
        return (
          <g>
            <rect
              x={x}
              y={y}
              width={BOX_W}
              height={BOX_H}
              fill="rgba(17,23,34,0.9)"
              stroke={i === nodes.length - 1 ? color : 'rgba(148,163,184,0.3)'}
              stroke-width="1"
            />
            <text
              x={x + BOX_W / 2}
              y={y + BOX_H / 2 + 4}
              text-anchor="middle"
              font-family="'JetBrains Mono', monospace"
              font-size="11"
              fill={i === nodes.length - 1 ? color : '#94A3B8'}
            >
              {n.length > 20 ? n.slice(0, 19) + '…' : n}
            </text>
            <text
              x={x + 6}
              y={y - 5}
              font-family="'JetBrains Mono', monospace"
              font-size="9"
              fill="rgba(100,116,139,0.9)"
            >
              {String(i + 1).padStart(2, '0')}
            </text>
            {i < nodes.length - 1 && (
              <g>
                <line
                  x1={x + BOX_W}
                  y1={y + BOX_H / 2}
                  x2={x + BOX_W + GAP - 8}
                  y2={y + BOX_H / 2}
                  stroke={color}
                  stroke-width="1"
                  stroke-dasharray="4 3"
                  opacity="0.6"
                />
                <path
                  d={`M ${x + BOX_W + GAP - 8} ${y + BOX_H / 2 - 4} l 8 4 l -8 4 z`}
                  fill={color}
                  opacity="0.8"
                />
              </g>
            )}
          </g>
        );
      })
    }
  </svg>
</figure>
