---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PointMesh from '../components/islands/PointMesh';
import HeroCollapse from '../components/islands/HeroCollapse';
import PipelineRail from '../components/islands/PipelineRail';
import Cursor from '../components/islands/Cursor';
import Terminal from '../components/islands/Terminal';
import SkillConstellation from '../components/islands/SkillConstellation';
import { identity, stats, education, experience, projects, achievements, research } from '../data/profile';

const spark = 'M0 14 L8 11 L16 12 L24 7 L32 9 L40 4 L48 6 L56 2';
const stampColor = (s: string) =>
  s.includes('WINNER') ? 'border-mint/50 text-mint' : s.includes('LIVE') ? 'border-mint/50 text-mint' : 'border-violet/50 text-violet';
---

<Base>
  <PointMesh client:load />
  <Cursor client:load />
  <PipelineRail client:load />
  <Nav />

  <main>
    <!-- ============ HERO: SUPERPOSITION ============ -->
    <section id="home" class="relative flex min-h-screen items-center">
      <div class="mx-auto w-full max-w-content px-4 pt-24 md:px-6 lg:pl-24">
        <p class="eyebrow mb-6"><b>00</b> · system under observation</p>
        <HeroCollapse client:load name={identity.name} tagline={identity.tagline} />
      </div>
      <a
        href="#about"
        class="absolute bottom-8 left-1/2 -translate-x-1/2 font-mono text-xs text-dim transition-colors hover:text-mint"
        aria-label="Scroll to about section"
      >scroll ▼</a>
    </section>

    <!-- ============ ABOUT: MISSION BRIEFING ============ -->
    <section id="about" class="mx-auto max-w-content px-4 py-24 md:px-6 lg:pl-24">
      <p class="eyebrow reveal"><b>01</b> · mission briefing</p>
      <h2 class="reveal display-h mt-5 text-ink">
        Security is an AI problem.<br />
        <span class="text-violet">AI is a security problem.</span>
      </h2>
      <div class="mt-10 grid gap-10 lg:grid-cols-[1.4fr_1fr]">
        <div class="reveal">
          <p class="leading-relaxed text-dim">{identity.summary}</p>
          <p class="mt-4 leading-relaxed text-dim">
            I work on both sides of that loop — building ML systems that detect threats, and studying
            how AI systems themselves can be attacked. My training ground spans academic research labs,
            government security operations centers, and national hackathon floors.
          </p>
          <div class="mt-6 flex flex-wrap gap-2">
            {['Builder', 'Researcher', 'Problem Solver', 'Security-Conscious Engineer'].map((t) => (
              <span class="border border-line px-3 py-1 font-mono text-xs text-dim">{t}</span>
            ))}
          </div>
        </div>
        <div class="reveal panel p-5">
          <p class="font-mono text-xs uppercase tracking-widest text-dim">education record</p>
          <p class="mt-3 font-mono text-sm font-medium text-ink">{education.school}</p>
          <p class="mt-1 text-sm text-dim">{education.degree}</p>
          <p class="mt-1 font-mono text-xs text-dim/70">{education.period} · {education.location}</p>
          <p class="mt-3 font-mono text-sm">
            <span class="text-dim">CGPA</span>
            <span class="ml-2 text-mint">{education.gpa}</span>
          </p>
          <div class="mt-4 border-t border-line pt-4">
            <p class="font-mono text-xs text-dim">coursework/</p>
            <p class="mt-2 text-xs leading-6 text-dim">{education.coursework.join(' · ')}</p>
          </div>
        </div>
      </div>

      <!-- Monitored metrics -->
      <div class="mt-14 grid grid-cols-2 gap-px border border-line bg-line lg:grid-cols-4">
        {stats.map((s) => (
          <div class="reveal bg-surface p-5">
            <div class="flex items-end justify-between">
              <p class="font-mono text-3xl font-medium text-mint" data-count={s.value}>0</p>
              <svg viewBox="0 0 56 16" class="h-4 w-14 opacity-50" aria-hidden="true">
                <path d={spark} fill="none" stroke="#8B5CFF" stroke-width="1.2" />
              </svg>
            </div>
            <p class="mt-1 font-mono text-xs uppercase tracking-wider text-ink">{s.label}</p>
            <p class="mt-1 text-xs text-dim">{s.detail}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ============ EXPERIENCE: LOG STREAM ============ -->
    <section id="experience" class="border-t border-line bg-surface/40">
      <div class="mx-auto max-w-content px-4 py-24 md:px-6 lg:pl-24">
        <p class="eyebrow reveal"><b>02</b> · log stream</p>
        <h2 class="reveal display-h mt-5 text-ink">Experience</h2>
        <p class="reveal mt-3 font-mono text-xs text-dim">tail -f /var/log/career.log · newest first · select a line to expand</p>
        <div class="mt-10 border border-line bg-void/50">
          {experience.map((e) => (
            <details class="log-entry reveal group border-b border-line last:border-b-0">
              <summary class="flex flex-wrap items-baseline gap-x-4 gap-y-1 px-5 py-4" data-cursor="expand">
                <span class="chev font-mono text-xs text-mint">▸</span>
                <span class="font-mono text-xs text-dim/80 w-40">[{e.period}]</span>
                <span class="font-mono text-sm font-medium text-ink">{e.role}</span>
                <span class="font-mono text-xs text-violet">@ {e.org}</span>
              </summary>
              <div class="px-5 pb-5 pl-12">
                <ul class="space-y-1.5 text-sm leading-relaxed text-dim">
                  {e.points.map((p) => (
                    <li class="flex gap-2">
                      <span class="mt-[9px] h-1 w-1 shrink-0 bg-mint/70" />
                      <span>{p}</span>
                    </li>
                  ))}
                </ul>
                <div class="mt-3 flex flex-wrap gap-2">
                  {e.tags.map((t) => (
                    <span class="bg-surface px-2 py-0.5 font-mono text-[11px] text-dim">{t}</span>
                  ))}
                </div>
              </div>
            </details>
          ))}
        </div>

        <!-- Research interests strip -->
        <div class="reveal panel mt-6 border-violet/25 p-6">
          <p class="font-mono text-xs uppercase tracking-widest text-violet">{research.heading}</p>
          <p class="mt-3 max-w-3xl text-sm leading-relaxed text-dim">{research.body}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {research.exploring.map((r) => (
              <span class="border border-violet/30 px-3 py-1 font-mono text-xs text-violet/90">exploring: {r}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PROJECTS: CASE FILES ============ -->
    <section id="projects" class="mx-auto max-w-content px-4 py-24 md:px-6 lg:pl-24">
      <p class="eyebrow reveal"><b>03</b> · case files</p>
      <h2 class="reveal display-h mt-5 text-ink">Projects</h2>
      <p class="reveal mt-3 max-w-2xl text-sm text-dim">
        Six case files. Hover to declassify — open one for the full breakdown: problem, architecture, stack, impact, learnings.
      </p>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        {projects.map((p, i) => (
          <a href={`/projects/${p.slug}/`} data-cursor="declassify" class="case reveal panel group relative block p-6 transition-colors hover:border-mint/40">
            <div class="flex items-start justify-between gap-4">
              <p class="font-mono text-[11px] uppercase tracking-widest text-dim/80">
                file_{String(i + 1).padStart(2, '0')} · {p.codename}
              </p>
              <span class={`stamp shrink-0 ${stampColor(p.status)}`}>{p.status.split(' · ')[0]}</span>
            </div>
            <h3 class="mt-4 font-mono text-xl font-medium text-ink transition-colors group-hover:text-mint">
              {p.name}
            </h3>
            <p class="redacted mt-2 text-sm leading-relaxed text-dim">
              {p.oneLiner}
              <span class="bar" style="top:0.15em;width:88%" aria-hidden="true"></span>
              <span class="bar" style="top:1.45em;width:64%;transition-delay:60ms" aria-hidden="true"></span>
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {p.stack.slice(0, 4).map((s) => (
                <span class="bg-surface px-2 py-0.5 font-mono text-[11px] text-dim">{s}</span>
              ))}
            </div>
            <p class="mt-5 font-mono text-xs text-dim/80 transition-colors group-hover:text-mint">open case file →</p>
          </a>
        ))}
      </div>
    </section>

    <!-- ============ SKILLS: CONSTELLATION ============ -->
    <section id="skills" class="border-t border-line bg-surface/40">
      <div class="mx-auto max-w-content px-4 py-24 md:px-6 lg:pl-24">
        <p class="eyebrow reveal"><b>04</b> · capability map</p>
        <h2 class="reveal display-h mt-5 text-ink">Skill constellation</h2>
        <p class="reveal mt-3 max-w-2xl text-sm text-dim">Three clusters, one system. Node size reflects depth of use — hover to isolate a domain.</p>
        <div class="reveal mt-8">
          <SkillConstellation client:visible />
        </div>
      </div>
    </section>

    <!-- ============ ACHIEVEMENTS: VERIFIED RECORD ============ -->
    <section id="achievements" class="mx-auto max-w-content px-4 py-24 md:px-6 lg:pl-24">
      <p class="eyebrow reveal"><b>05</b> · verified record</p>
      <h2 class="reveal display-h mt-5 text-ink">Achievements</h2>
      <div class="mt-10 border border-line bg-void/50">
        {achievements.map((a) => (
          <div class="reveal flex flex-wrap items-baseline gap-x-4 gap-y-1 border-b border-line px-5 py-4 last:border-b-0 transition-colors hover:bg-mint/[0.04]">
            <span class="font-mono text-xs text-dim/80 w-12">{a.year}</span>
            <span class="w-4 font-mono text-sm text-mint">{a.kind === 'gold' ? '★' : '·'}</span>
            <span class="flex-1 font-mono text-sm font-medium text-ink min-w-[16rem]">{a.title}</span>
            <span class="hidden text-xs text-dim md:block md:max-w-sm">{a.body}</span>
            <span class="border border-mint/40 px-2 py-0.5 font-mono text-[10px] tracking-widest text-mint">verified</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ============ CONTACT + TERMINAL ============ -->
    <section id="contact" class="border-t border-line bg-surface/40">
      <div class="mx-auto max-w-content px-4 py-24 md:px-6 lg:pl-24">
        <div class="grid items-start gap-10 lg:grid-cols-2">
          <div>
            <p class="eyebrow reveal"><b>06</b> · secure channel</p>
            <h2 class="reveal display-h mt-5 text-ink">Open a<br />secure channel</h2>
            <p class="reveal mt-4 max-w-md text-sm leading-relaxed text-dim">
              Recruiting, research collaboration, hackathon teams, or hard problems in AI × security —
              I respond fast on LinkedIn. Or skip the pleasantries — type
              <span class="font-mono text-mint">sudo hire</span> below.
            </p>
            <div class="reveal mt-7 flex flex-wrap gap-3">
              <a href={identity.linkedin} target="_blank" rel="noopener noreferrer" data-cursor="connect"
                class="panel px-5 py-2.5 font-mono text-sm text-mint transition-colors hover:border-mint/60">
                linkedin →
              </a>
              <a href={identity.github} target="_blank" rel="noopener noreferrer"
                class="border border-line px-5 py-2.5 font-mono text-sm text-dim transition-colors hover:border-violet/60 hover:text-ink">
                github/t4shee
              </a>
            </div>
          </div>
          <div id="terminal" class="reveal">
            <Terminal client:visible />
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
