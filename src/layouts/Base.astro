---
import '@fontsource/fraunces/400.css';
import '@fontsource/fraunces/500.css';
import '@fontsource/fraunces/500-italic.css';
import '@fontsource/ibm-plex-sans/400.css';
import '@fontsource/ibm-plex-sans/500.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import { identity } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
  path?: string;
}

const {
  title = `${identity.name} — ${identity.title}`,
  description = `${identity.name} · ${identity.title}. ${identity.tagline} National hackathon winner, IndiaSkills medallist, GATE CSE qualified. AI/ML, cybersecurity, SOC operations, LLM security, post-quantum cryptography.`,
  path = '/',
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://tasheebisht.pages.dev';
const canonical = `${site}${path}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: identity.name,
  url: site,
  jobTitle: identity.title,
  description: identity.tagline,
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'National Forensic Sciences University' },
  knowsAbout: [
    'Artificial Intelligence', 'Machine Learning', 'Cybersecurity', 'LLM Security',
    'SOC Operations', 'Post-Quantum Cryptography', 'Software Engineering', 'DevSecOps',
  ],
  sameAs: [identity.github, identity.linkedin],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={identity.name} />
    <meta name="keywords" content="Tashee Bisht, AI security engineer, cybersecurity researcher, machine learning, LLM security, post-quantum cryptography, SOC, NFSU, portfolio" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#0B0A0A" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={identity.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site}/og-image.svg`} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site}/og-image.svg`} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />

    <script is:inline>
      // Runs before paint (end of body is fine for class, but set ASAP):
      // theme persisted in localStorage; dark is the default brand theme.
      (function () {
        try {
          if (localStorage.getItem('theme') === 'light')
            document.documentElement.classList.add('light');
        } catch (e) {}
      })();
    </script>

    <script>
      // Scroll-reveal: single quiet 300ms rise per element
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -30px 0px' }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // Monitored metrics: count-up on scroll-in
      const counters = document.querySelectorAll<HTMLElement>('[data-count]');
      const cio = new IntersectionObserver((entries) => {
        for (const e of entries) {
          if (!e.isIntersecting) continue;
          cio.unobserve(e.target);
          const el = e.target as HTMLElement;
          const target = el.dataset.count ?? '';
          const num = parseFloat(target);
          if (isNaN(num) || matchMedia('(prefers-reduced-motion: reduce)').matches) {
            el.textContent = target;
            continue;
          }
          const suffix = target.replace(String(num), '');
          const dec = (String(num).split('.')[1] || '').length;
          const t0 = performance.now();
          const dur = 900;
          const tick = (t: number) => {
            const k = Math.min((t - t0) / dur, 1);
            const v = num * (1 - Math.pow(1 - k, 3));
            el.textContent = v.toFixed(dec) + suffix;
            if (k < 1) requestAnimationFrame(tick);
            else el.textContent = target;
          };
          requestAnimationFrame(tick);
        }
      }, { threshold: 0.5 });
      counters.forEach((c) => cio.observe(c));

      // Theme toggle
      const meta = document.querySelector('meta[name="theme-color"]');
      const applyMeta = () =>
        meta?.setAttribute('content',
          document.documentElement.classList.contains('light') ? '#F6F0E6' : '#0B0A0A');
      applyMeta();
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const isLight = document.documentElement.classList.toggle('light');
        try { localStorage.setItem('theme', isLight ? 'light' : 'dark'); } catch (e) {}
        applyMeta();
        window.dispatchEvent(new CustomEvent('themechange'));
      });
    </script>
  </body>
</html>
